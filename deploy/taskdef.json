{
  "family": "pulseboard-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::121720446284:role/pulseboard-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::121720446284:role/pulseboard-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "pulseboard-backend",
      "image": "<IMAGE_URI>",
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",          "value": "production" },
        { "name": "PORT",              "value": "3001" },
        { "name": "AWS_REGION",        "value": "us-east-1" },
        { "name": "DYNAMO_TABLE_NAME", "value": "pulseboard-metrics" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/pulseboard",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}